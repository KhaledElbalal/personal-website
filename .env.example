# ── Sanity (Next.js site — read side) ──────────────────────────────
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-10-01

# Shared secret for the /api/revalidate webhook (server only). Generate a
# random string and set the same value on the Sanity webhook.
SANITY_REVALIDATE_SECRET=

# Optional: read token for future preview / private datasets (server only).
# SANITY_API_READ_TOKEN=
